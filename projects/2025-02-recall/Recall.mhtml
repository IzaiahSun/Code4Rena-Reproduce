k1"> (</span><span class=3D"mtk12">genesisCircSupply</span><span class=3D"m=
tk1"> &gt; </span><span class=3D"mtk7">0</span><span class=3D"mtk1">) {</sp=
an></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">    </span><span class=3D"mtk11">SubnetActorGetterFacet</span><span class=
=3D"mtk1">(</span><span class=3D"mtk12">msg</span><span class=3D"mtk1">.</s=
pan><span class=3D"mtk12">sender</span><span class=3D"mtk1">).</span><span =
class=3D"mtk11">supplySource</span><span class=3D"mtk1">().</span><span cla=
ss=3D"mtk11">lock</span><span class=3D"mtk1">(</span><span class=3D"mtk12">=
genesisCircSupply</span><span class=3D"mtk1">);</span></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">}</span></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
5">if</span><span class=3D"mtk1"> (</span><span class=3D"mtk12">collateral<=
/span><span class=3D"mtk1"> &gt; </span><span class=3D"mtk7">0</span><span =
class=3D"mtk1">) {</span></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">    </span><span class=3D"mtk11">SubnetActorGetterFacet</span><span class=
