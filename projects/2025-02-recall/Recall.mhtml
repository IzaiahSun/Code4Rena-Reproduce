lass=3D"mtk12">AssetKind</span><span class=3D"mtk1">.</span><span class=3D"=
mtk12">Native</span><span class=3D"mtk1">) {</span></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">    </span><span class=3D"mtk3">// ERC20 handling</span></span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">} </span><span class=3D"mtk15">else</span><span class=3D"mtk1"> {</span><=
/span></span>
<span class=3D"grvsc-line"><span class=3D"grvsc-source"><span class=3D"mtk1=
">    </span><span class=3D"mtk11">require</span><span class=3D"mtk1">(</sp=
an><span class=3D"mtk12">msg</span><span class=3D"mtk1">.</span><span class=
